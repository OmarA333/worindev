{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "moduleResolution": "node16",
    "module": "Node16",
    "target": "ES2022",

    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src", "prisma", "prisma.config.ts"]
}