generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum RolUsuario {
  ADMIN
  EMPRESA
  CANDIDATO
}

enum EstadoUsuario {
  ACTIVO
  INACTIVO
  SUSPENDIDO
}

enum Modalidad {
  PRESENCIAL
  REMOTO
  HIBRIDO
}

enum TipoContrato {
  INDEFINIDO
  FIJO
  PRESTACION
  PRACTICAS
  TEMPORAL
}

enum EstadoVacante {
  ACTIVA
  PAUSADA
  CERRADA
}

enum EstadoPostulacion {
  PENDIENTE
  EN_REVISION
  ENTREVISTA
  RECHAZADO
  ACEPTADO
}

enum EstadoEntrevista {
  PROGRAMADA
  REALIZADA
  CANCELADA
}

enum TipoTest {
  HARD_SKILL
  SOFT_SKILL
  PSICOMETRIA
  LOGISTICA
}

enum NivelEducacion {
  BACHILLER
  TECNICO
  TECNOLOGO
  PROFESIONAL
  ESPECIALIZACION
  MAESTRIA
  DOCTORADO
}

// ─── USUARIO BASE ─────────────────────────────────────────────────────────────

model Usuario {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  password  String
  rol       RolUsuario
  estado    EstadoUsuario @default(ACTIVO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  candidato  Candidato?
  empresa    Empresa?
  otps       PasswordResetOtp[]

  @@map("usuario")
}

// ─── CANDIDATO ────────────────────────────────────────────────────────────────

model Candidato {
  id                  Int            @id @default(autoincrement())
  usuarioId           Int            @unique
  nombre              String
  apellido            String
  telefono            String?
  ciudad              String?
  departamento        String?
  foto                String?
  cvUrl               String?
  nivelEducacion      NivelEducacion?
  tituloObtenido      String?
  anosExperiencia     Int            @default(0)
  pretensionSalarial  Int?
  disponibilidad      String?        // "Inmediata", "15 días", "1 mes"
  modalidadPreferida  Modalidad?
  resumen             String?
  linkedinUrl         String?
  githubUrl           String?
  matchScore          Float          @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  usuario       Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  habilidades   CandidatoHabilidad[]
  experiencias  Experiencia[]
  educaciones   Educacion[]
  postulaciones Postulacion[]
  testResultados TestResultado[]
  referencias   Referencia[]

  @@map("candidato")
}

model CandidatoHabilidad {
  id          Int    @id @default(autoincrement())
  candidatoId Int
  habilidad   String
  nivel       String @default("Intermedio") // Básico, Intermedio, Avanzado, Experto

  candidato Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  @@unique([candidatoId, habilidad])
  @@map("candidato_habilidad")
}

model Experiencia {
  id          Int      @id @default(autoincrement())
  candidatoId Int
  empresa     String
  cargo       String
  descripcion String?
  fechaInicio DateTime
  fechaFin    DateTime?
  actual      Boolean  @default(false)
  createdAt   DateTime @default(now())

  candidato Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  @@map("experiencia")
}

model Educacion {
  id          Int      @id @default(autoincrement())
  candidatoId Int
  institucion String
  titulo      String
  nivel       NivelEducacion
  fechaInicio DateTime
  fechaFin    DateTime?
  actual      Boolean  @default(false)
  createdAt   DateTime @default(now())

  candidato Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  @@map("educacion")
}

model Referencia {
  id          Int      @id @default(autoincrement())
  candidatoId Int
  nombre      String
  cargo       String
  empresa     String
  email       String
  telefono    String?
  verificado  Boolean  @default(false)
  tokenVerif  String?  @unique
  createdAt   DateTime @default(now())

  candidato Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  @@map("referencia")
}

// ─── EMPRESA ──────────────────────────────────────────────────────────────────

model Empresa {
  id              Int      @id @default(autoincrement())
  usuarioId       Int      @unique
  nombre          String
  rut             String?  @unique
  sector          String?
  tamano          String?  // "1-10", "11-50", "51-200", "200+"
  ciudad          String?
  descripcion     String?
  logoUrl         String?
  sitioWeb        String?
  cultura         String?
  verificada      Boolean  @default(false)
  planActivo      String   @default("BASICO") // BASICO, PRO, ENTERPRISE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  vacantes  Vacante[]

  @@map("empresa")
}

// ─── VACANTE ──────────────────────────────────────────────────────────────────

model Vacante {
  id              Int           @id @default(autoincrement())
  empresaId       Int
  titulo          String
  descripcion     String
  requisitos      String?
  habilidades     String[]
  ciudad          String?
  modalidad       Modalidad     @default(PRESENCIAL)
  tipoContrato    TipoContrato  @default(INDEFINIDO)
  salarioMin      Int?
  salarioMax      Int?
  nivelEducacion  NivelEducacion?
  anosExperiencia Int           @default(0)
  estado          EstadoVacante @default(ACTIVA)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  empresa       Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  postulaciones Postulacion[]
  entrevistas   EntrevistaGrupal[]

  @@map("vacante")
}

// ─── POSTULACIÓN ──────────────────────────────────────────────────────────────

model Postulacion {
  id          Int               @id @default(autoincrement())
  vacanteId   Int
  candidatoId Int
  matchScore  Float             @default(0)
  estado      EstadoPostulacion @default(PENDIENTE)
  notasAdmin  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vacante   Vacante   @relation(fields: [vacanteId],   references: [id], onDelete: Cascade)
  candidato Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  @@unique([vacanteId, candidatoId])
  @@map("postulacion")
}

// ─── ENTREVISTA GRUPAL ────────────────────────────────────────────────────────

model EntrevistaGrupal {
  id          Int              @id @default(autoincrement())
  vacanteId   Int
  fecha       DateTime
  modalidad   Modalidad        @default(PRESENCIAL)
  enlace      String?
  direccion   String?
  estado      EstadoEntrevista @default(PROGRAMADA)
  maxCandidatos Int            @default(10)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  vacante      Vacante                @relation(fields: [vacanteId], references: [id], onDelete: Cascade)
  invitaciones InvitacionEntrevista[]

  @@map("entrevista_grupal")
}

model InvitacionEntrevista {
  id             Int      @id @default(autoincrement())
  entrevistaId   Int
  candidatoId    Int
  confirmado     Boolean  @default(false)
  tokenConfirm   String?  @unique @default(uuid())
  expiresAt      DateTime
  respondidoAt   DateTime?
  createdAt      DateTime @default(now())

  entrevista EntrevistaGrupal @relation(fields: [entrevistaId], references: [id], onDelete: Cascade)

  @@unique([entrevistaId, candidatoId])
  @@map("invitacion_entrevista")
}

// ─── TESTS DE COMPETENCIAS ────────────────────────────────────────────────────

model Test {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  tipo        TipoTest
  descripcion String?
  duracion    Int      // minutos
  peso        Float    // porcentaje del match score (0.0 - 1.0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())

  preguntas  Pregunta[]
  resultados TestResultado[]

  @@map("test")
}

model Pregunta {
  id       Int    @id @default(autoincrement())
  testId   Int
  texto    String
  tipo     String @default("OPCION_MULTIPLE") // OPCION_MULTIPLE, ESCALA, ABIERTA
  opciones Json?  // [{texto, valor}]
  orden    Int    @default(0)

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("pregunta")
}

model TestResultado {
  id          Int      @id @default(autoincrement())
  candidatoId Int
  testId      Int
  puntaje     Float    // 0-100
  respuestas  Json?
  completadoAt DateTime @default(now())

  candidato Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
  test      Test      @relation(fields: [testId],      references: [id])

  @@unique([candidatoId, testId])
  @@map("test_resultado")
}

// ─── OTP RECUPERACIÓN CONTRASEÑA ─────────────────────────────────────────────

model PasswordResetOtp {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  email     String
  otp       String
  expiresAt DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("password_reset_otp")
}
